{
  "model_path": "Wan-AI/Wan2.1-I2V-14B-480P-Diffusers",
  "dataset_base_path": "./data_wan",
  "metadata_csv": "./data_wan/metadata.csv",
  "output_dir": "./checkpoints/wan_render_drrobot_fsdp",
  "num_frames": 17,
  "height": 240,
  "width": 432,
  "dataset_repeat": 32,
  "learning_rate": 2e-05,
  "lr_scheduler": "cosine_warmup",
  "lr_warmup_steps": 100,
  "lr_min_ratio": 0.0,
  "lr_epoch_decay_start": 300,
  "lr_epoch_decay_end": 800,
  "weight_decay": 0.001,
  "num_epochs": 500,
  "gradient_accumulation_steps": 1,
  "seed": 42,
  "trainable": "render_only",
  "max_sequence_length": 256,
  "mixed_precision": "bf16",
  "unfreeze_last_n_blocks": 8,
  "num_workers": 4,
  "save_every_n_epochs": 10,
  "log_every_n_steps": 1,
  "max_grad_norm": 1.0,
  "abort_on_nan": false,
  "condition_usage_sanity_samples": 0,
  "disable_render_gate": false,
  "lambda_tracks": 0.1,
  "ref_frame": 3,
  "max_query_points": 128,
  "wandb_project": "wan_flow_drrobot",
  "wandb_run_name": "overfit_10vid_cond_tracks",
  "wandb_mode": "online",
  "drop_render_conditioning": false
}
{
  "model_path": "Wan-AI/Wan2.1-I2V-14B-480P-Diffusers",
  "dataset_base_path": "data_wan_data",
  "metadata_csv": "data_wan_data/metadata_20vids.csv",
  "output_dir": "./checkpoints/wan_render_drrobot_aa_bypass_20vids",

  "num_frames": 17,
  "height": 240,
  "width": 432,

  "dataset_repeat": 16,
  "num_epochs": 80,
  "save_every_n_epochs": 10,

  "learning_rate": 2e-05,
  "lr_scheduler": "cosine_warmup",
  "lr_warmup_steps": 100,
  "lr_min_ratio": 0.0,
  "weight_decay": 0.001,
  "gradient_accumulation_steps": 1,
  "max_grad_norm": 1.0,
  "seed": 42,

  "trainable": "render_only",
  "unfreeze_last_n_blocks": 8,
  "disable_render_gate": false,

  "max_sequence_length": 256,
  "mixed_precision": "bf16",
  "num_workers": 4,
  "log_every_n_steps": 1,

  "condition_usage_sanity_samples": 20,
  "render_dropout_prob": 0.1,

  "lambda_tracks": 0.1,
  "ref_frame": 30,
  "max_query_points": 128,

  "ignore_prompts": true,

  "use_embodiment_adapter": true,
  "embodiment_kwargs": {
    "num_state_tokens": 8,
    "state_hidden_dim": 512,
    "adaln_rank": 512,
    "adapter_every_k": 8,
    "adapter_num_heads": 8,
    "spatial_pool": 4,
    "use_action_aware_adaln": true,
    "action_aware_kwargs": {
      "spatial_pool": 2,
      "action_dim": null,
      "hidden_dim": 512,
      "adaln_rank": 512,
      "num_heads": 8
    }
  },

  "wandb_project": "wan_flow_drrobot",
  "wandb_run_name": "aa_bypass_20vids_v1",
  "wandb_mode": "online"
}

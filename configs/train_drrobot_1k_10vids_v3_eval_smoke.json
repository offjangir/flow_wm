{
  "_comment_target": "FSDP smoke for v3 + in-training eval. 10 vids × 4 epochs × save_every=2 = 2 save points (epoch 1 and 3). eval_every_n_epochs=1 = flow-MSE every epoch; eval_video_at_save=true = full PSNR/SSIM at epoch 1 and 3. Verifies the eval-block plumbing (cache precompute, FSDP summon, VAE reload, wandb logging) before committing to a 50-hr full run.",

  "model_path": "Wan-AI/Wan2.1-I2V-14B-480P-Diffusers",
  "dataset_base_path": "data_wan_1k",
  "metadata_csv": "data_wan_1k/train_metadata_10.csv",
  "output_dir": "./checkpoints/wan_render_drrobot_1k_10vids_v3_eval_smoke",

  "num_frames": 81,
  "height": 240,
  "width": 432,

  "action_stats_path": "data_wan_1k/action_stats.json",
  "action_field": "state",

  "precompute_cache_path": "data_wan_1k/precompute_cache_10vids_v2_81f.pt",

  "dataset_repeat": 1,
  "num_epochs": 4,
  "save_every_n_epochs": 2,

  "learning_rate": 2e-05,
  "gate_lr_multiplier": 1.0,
  "lr_scheduler": "cosine_warmup",
  "lr_warmup_steps": 5,
  "lr_min_ratio": 0.0,
  "weight_decay": 0.001,
  "gradient_accumulation_steps": 1,
  "max_grad_norm": 1.0,
  "seed": 42,

  "trainable": "render_only",
  "unfreeze_last_n_blocks": 8,
  "disable_render_gate": false,

  "max_sequence_length": 256,
  "mixed_precision": "bf16",
  "num_workers": 2,
  "log_every_n_steps": 1,

  "condition_usage_sanity_samples": 0,
  "render_dropout_prob": 0.1,

  "lambda_tracks": 0.1,
  "ref_frame": 1,
  "max_query_points": 128,

  "ignore_prompts": true,

  "use_embodiment_adapter": false,
  "legacy_render_variant": "v3",
  "v3_adapter_kwargs": {
    "action_dim": 8,
    "hidden_dim": 512,
    "spatial_downsample": 2,
    "action_temporal_align": "avg_pool",
    "out_proj_init": "kaiming"
  },

  "eval_every_n_epochs": 1,
  "eval_csv_heldout": "data_wan_1k/train_metadata_test.csv",
  "eval_n_heldout_flow": 3,
  "eval_timesteps_per_sample": 2,
  "eval_video_at_save": false,

  "wandb_project": "wan_flow_drrobot",
  "wandb_run_name": "1k_10vids_fsdp_v3_eval_smoke",
  "wandb_mode": "online"
}

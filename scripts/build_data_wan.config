# Config for scripts/build_data_wan.sh — shell syntax, sourced by the script.
# Edit the values below; comment-out a line to fall back to the script default.
#
# CLI / env precedence:
#   real env var > this file > script default
# i.e. `DROID_ROOT=/foo ./scripts/build_data_wan.sh` still wins over the value
# set here.

# ─── Inputs ──────────────────────────────────────────────────────────────────

# DROID dataset root (must contain scene_*/recordings/MP4/<serial>.mp4,
# metadata_*.json, trajectory.h5).
DROID_ROOT="/data/yjangir/sidegig/wm/data/droid_10_demos"

# Trained DrRobot run directory (must contain cfg_args, point_cloud/, etc).
MODEL_PATH="/data/yjangir/sidegig/wm/drrobot/output/franka_emika_panda_complement1"

# AllTracker checkout (https://github.com/aharley/alltracker).
ALLTRACKER_ROOT="/data/yjangir/sidegig/alltracker"

# ─── Output ──────────────────────────────────────────────────────────────────

# Output root. Note: prepare_data_wan.py hard-codes <repo>/data_wan, so for
# a different name, symlink it after (e.g. `ln -s data_wan data_wan_data`).
DATA_WAN="/data/yjangir/sidegig/wm/data_wan"

# ─── Camera ──────────────────────────────────────────────────────────────────

# Which DROID camera to use as the training target + tracks source.
#   wrist  -> 16787047
#   ext1   -> 20103212
#   ext2   -> 20655732
CAMERA_KEY="ext1"
DROID_SERIAL="20103212"

# ─── Render (phase 1) ────────────────────────────────────────────────────────

# Output FPS: "match" / "auto" reads it from the real DROID MP4 (e.g. 60).
# A number forces a fixed rate.
RENDER_FPS="match"

# Rasterizer clear color behind Gaussians: white | black.
RENDER_BG="black"

# ─── AllTracker dense tracks (phase 2) ───────────────────────────────────────

# Sparse query grid (also saved alongside dense, for metadata.csv `tracks`).
TRACK_GRID_X=32
TRACK_GRID_Y=20

# Max side AllTracker sees (1024 = default; bigger = more VRAM).
TRACK_IMAGE_SIZE=1024

# ─── Pipeline ────────────────────────────────────────────────────────────────

# Python interpreter (set to your conda env, e.g.
# /home/yjangir/miniconda3/envs/dr/bin/python).
PY="python"

# 0 = process all scenes; >0 = cap (smoke tests).
MAX_SCENES=0

# Phase toggles (1 = skip).
SKIP_RENDER=0
SKIP_TRACKS=0
SKIP_METADATA=0

# Smoke-test config: build data_wan/ from data/droid_5k_test (10 scenes,
# ext1-only — serial 20103212).
#
# Usage:
#   ./scripts/build_data_wan.sh --config scripts/build_data_wan.droid_5k_test.config
#
# This config sets SKIP_RENDER=1 by default — phase 1 needs a Franka Panda
# DrRobot checkpoint that isn't on disk yet. Once you have one, set
# MODEL_PATH to its directory and unset SKIP_RENDER (or `SKIP_RENDER=0`).

# ─── Inputs ──────────────────────────────────────────────────────────────────
DROID_ROOT="/data/yjangir/sidegig/wm/data/droid_5k_test"

# Trained DrRobot Franka Panda run dir (will be copied here later).
MODEL_PATH="/data/yjangir/sidegig/wm/drrobot/output/franka_emika_panda_complement1"

ALLTRACKER_ROOT="/data/yjangir/sidegig/alltracker"

# ─── Output ──────────────────────────────────────────────────────────────────
DATA_WAN="/data/yjangir/sidegig/wm/data_wan"

# ─── Camera (only ext1 / 20103212 is downloaded for droid_5k_test) ──────────
CAMERA_KEY="ext1"
DROID_SERIAL="20103212"

# ─── Render (phase 1) ────────────────────────────────────────────────────────
RENDER_FPS="match"
RENDER_BG="black"

# ─── AllTracker (phase 2) ────────────────────────────────────────────────────
TRACK_GRID_X=32
TRACK_GRID_Y=20
TRACK_IMAGE_SIZE=1024

# ─── Pipeline ────────────────────────────────────────────────────────────────
PY="/home/yjangir/miniconda3/envs/dr/bin/python"

# 0 = process all scenes; >0 = cap (smoke tests).
MAX_SCENES=2

# Phase toggles.
SKIP_RENDER=1     # no Franka Panda checkpoint yet — turn off when MODEL_PATH lands
SKIP_TRACKS=0
SKIP_METADATA=0
